---
import BaseLayout from './BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AudioPlayer from '../components/AudioPlayer.astro';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  description: string;
  audio?: string;
}

const { title, date, tags, description, audio } = Astro.props;

// Derive sync file path from audio path: /audio/slug.mp3 → /audio/sync/slug.json
const syncFile = audio ? audio.replace('/audio/', '/audio/sync/').replace('.mp3', '.json') : undefined;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={`${title} | The Startup at the End of the Universe`}>
  <SEO
    slot="head"
    title={title}
    description={description}
    article={true}
    publishDate={date}
  />

  <article>
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    {audio && <AudioPlayer src={audio} title={title} syncFile={syncFile} />}

    <div class="post-content">
      <slot />
    </div>

    <div class="ascii-divider">~*~*~*~*~*~*~*~*~*~*~</div>

    <div class="tags" style="margin-top: 1.5rem;">
      {tags.map((tag) => (
        <a href={`/tags/${tag}/`} class="tag">{tag}</a>
      ))}
    </div>

    <aside class="disclaimer">
      <strong>TEMPORAL DISCLAIMER:</strong> The views expressed in this post were written at the end of the universe, where time is a bit wobbly. Any factual errors are the fault of entropy, not the author.
    </aside>
  </article>
</BaseLayout>
