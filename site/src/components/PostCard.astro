---
interface Props {
  id: string;
  title: string;
  date: Date;
  description: string;
  tags: string[];
  towelRating?: number;
}

const { id, title, date, description, tags, towelRating } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const towelFull = '[@]';
---
<article class="post-card">
  <h2 class="post-card-title">
    <a href={`/blog/${id}/`}>&gt; {title}</a>
  </h2>
  <div class="post-card-meta">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    {towelRating && (
      <span class="towel-rating" title={`Towel Rating: ${towelRating}/5`}>
        {towelFull.repeat(towelRating)}
      </span>
    )}
  </div>
  <p class="post-card-description">{description}</p>
  <div class="tags">
    {tags.map((tag) => (
      <a href={`/tags/${tag}/`} class="tag">{tag}</a>
    ))}
  </div>
</article>
